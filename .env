# Project defaults loaded by direnv (.envrc) and by longeval/spark.py via
# python-dotenv. Override per-machine in .env.local (gitignored).

# JDK location for PySpark (host-specific — override in .env.local if needed).
JAVA_HOME=/nix/store/c3pl7bqrx3d2rc3dh98z6yaj0mv1p52g-openjdk-21.0.10+7
# pyjnius (used by pyserini.analysis) doesn't know about Nix's openjdk layout,
# so point it directly at libjvm.so.
JVM_PATH=/nix/store/c3pl7bqrx3d2rc3dh98z6yaj0mv1p52g-openjdk-21.0.10+7/lib/openjdk/lib/server/libjvm.so

# Python's bundled certifi doesn't include the host trust store on NixOS, so
# downloads (e.g. nltk corpora) fail with CERTIFICATE_VERIFY_FAILED. Point
# Python and requests at the system bundle.
SSL_CERT_FILE=/etc/ssl/certs/ca-bundle.crt
REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-bundle.crt

# Spark
SPARK_LOCAL_DIR=/mnt/data/tmp
PYSPARK_DRIVER_MEMORY=40g

# ir_datasets cache root (matches the default in scripts/download-longeval)
IR_DATASETS_HOME=/mnt/data/scratch/longeval
